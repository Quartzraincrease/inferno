{
  "name": "inferno-build",
  "private": true,
  "packageManager": "pnpm@11.2.2",
  "license": "MIT",
  "author": {
    "name": "Dominic Gannaway",
    "email": "dg@domgan.com"
  },
  "type": "module",
  "bugs": {
    "url": "https://github.com/infernojs/inferno/issues"
  },
  "homepage": "https://github.com/infernojs/inferno#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/infernojs/inferno.git"
  },
  "scripts": {
    "clean": "pnpm -r --filter './packages/*' exec rimraf dist tmpDist .rpt2_cache_development .rpt2_cache_production",
    "coveralls": "coveralls < coverage/lcov.info",
    "debug": "node --inspect-brk ./node_modules/jest/bin/jest --runInBand --no-cache --no-watchman",
    "docs-build": "cross-env NODE_ENV=production node docs/build.js",
    "docs-build:dev": "node docs/build.js",
    "prebuild": "pnpm run clean",
    "postbuild": "rimraf build; pnpm -r --filter './packages/*' exec rimraf tmpDist",
    "build": "pnpm run clean && tsc --build && pnpm run build:move-compiled && pnpm run build:move-types && pnpm run build:bundle && pnpm run print:size",
    "build:bundle": "pnpm -r --stream --filter './packages/*' exec node ../../scripts/rollup/build.js",
    "build:move-types": "pnpm -r --filter './packages/*' exec node ../../scripts/bundle/move-typedefs.js",
    "build:move-compiled": "pnpm -r --filter './packages/*' exec node ../../scripts/bundle/move-compiled.js",
    "print:size": "node scripts/bundle/bundle-size.js",
    "lint": "eslint packages/*",
    "lint:fix": "eslint --fix packages/*",
    "publish": "pnpm publish -r --filter './packages/*' --access public",
    "alpha": "pnpm publish -r --filter './packages/*' --tag next --access public",
    "version": "pnpm run build && pnpm run docs-build && git add docs && pnpm run test",
    "postinstall": "pnpm run build",
    "prettier": "prettier --write packages/*",
    "test": "pnpm run test:node && pnpm run test:node-nodom && pnpm run test:browser",
    "test:transformers": "cross-env InfernoCompat=0 pnpm --filter inferno-fixture-browser run test:swc && pnpm --filter inferno-fixture-browser run test:ts && pnpm --filter inferno-fixture-browser run test:swc",
    "test:node": "cross-env NODE_ENV=test jest --config ./jest.config.js --no-watchman",
    "test:node:debug": "cross-env NODE_ENV=test node --inspect-brk node_modules/jest/bin/jest.js --config ./jest.config-nodom.js --no-watchman --runInBand",
    "test:node-nodom": "cross-env NODE_ENV=test jest --config ./jest.config-nodom.js --no-watchman",
    "test:coverage": "cross-env NODE_ENV=test jest --runInBand --coverage --no-watchman",
    "test:browser": "pnpm run test:browser:nocompat && pnpm run test:browser:compat",
    "test:browser:compat": "cross-env InfernoCompat=1 pnpm --filter inferno-fixture-browser run test:swc",
    "test:browser:nocompat": "cross-env InfernoCompat=0 pnpm --filter inferno-fixture-browser run test:swc",
    "test:browser:debug": "cross-env InfernoCompat=1 pnpm --filter inferno-fixture-browser run debug:swc",
    "test:browser:debug-nocompat": "cross-env InfernoCompat=0 pnpm --filter inferno-fixture-browser run debug:swc",
    "test:browser:sauce": "pnpm --filter inferno-fixture-browser run test",
    "test:react": "pnpm --dir fixtures/react run test -- --forceExit",
    "test:memory": "node --expose-gc scripts/fakedom/uibench-reactlike/start.js",
    "test:memory:js-framework": "node --expose-gc scripts/fakedom/js-framework-bench/start.js",
    "test:memory:lifecycle": "node --expose-gc scripts/fakedom/uibench-lifecycle/start.js",
    "test:memory:lifecycle:debug": "node --inspect-brk --expose-gc scripts/fakedom/uibench-lifecycle/start.js",
    "test:memory:js-framework:debug": "node --inspect-brk --expose-gc scripts/fakedom/js-framework-bench/start.js"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-class-properties": "7.18.6",
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "@babel/preset-env": "7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@swc/core": "1.15.24",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "babel-plugin-inferno": "6.8.5",
    "cli-table": "^0.3.11",
    "concat-stream": "^2.0.0",
    "coveralls-next": "^6.0.1",
    "cross-env": "^10.1.0",
    "d3-scale-chromatic": "^3.1.0",
    "eslint": "^10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-inferno": "^7.40.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.2.1",
    "filesize": "^11.0.15",
    "globals": "^17.4.0",
    "gzip-size": "^7.0.0",
    "history": "^5.3.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-jasmine2": "^30.3.0",
    "jest-silent-reporter": "^0.6.0",
    "jsdom": "^29.0.2",
    "minimist": "^1.2.8",
    "mobx": "^6.15.0",
    "perf-monitor": "^0.6.0",
    "prettier": "^3.8.1",
    "rimraf": "^6",
    "rollup": "4.60.1",
    "swc-loader": "^0.2.7",
    "swc-plugin-inferno": "^2.14.0",
    "ts-plugin-inferno": "^6.1.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
